# E2E TLS Demo Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# AWS Account ID (required)
AWS_ACCOUNT_ID=

# AWS Region (default: ca-central-1)
AWS_REGION=ca-central-1

# Your Route53 domain (required)
# Example: myapp.example.com
DOMAIN=

# Route53 Hosted Zone ID for your domain (required)
# Find in Route53 console or: aws route53 list-hosted-zones
HOSTED_ZONE_ID=
